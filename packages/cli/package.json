{
  "name": "@korajs/cli",
  "version": "0.1.12",
  "description": "Kora.js CLI tooling and project scaffolding",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kora": "./dist/bin.js",
    "create-kora-app": "./dist/create.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./create": {
      "import": "./dist/create.js",
      "require": "./dist/create.cjs"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ tests/",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@korajs/core": "workspace:*",
    "citty": "^0.1.6"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsup": "^8.3.6",
    "vitest": "^3.0.4"
  },
  "license": "MIT"
}
