{
  "name": "@korajs/devtools",
  "version": "0.6.0",
  "description": "Browser DevTools extension for Kora.js with sync timeline, conflict inspector, and operation log",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./overlay": {
      "import": {
        "types": "./dist/overlay.d.ts",
        "default": "./dist/overlay.js"
      },
      "require": {
        "types": "./dist/overlay.d.cts",
        "default": "./dist/overlay.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node ./scripts/build-extension-assets.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@korajs/core": "workspace:*",
    "htm": "^3.1.1",
    "preact": "^10.29.1"
  },
  "devDependencies": {
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "license": "MIT"
}
