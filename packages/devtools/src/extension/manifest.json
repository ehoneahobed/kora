{
  "manifest_version": 3,
  "name": "Kora DevTools",
  "version": "0.0.0",
  "description": "DevTools panel for visualizing Kora sync, merges, and operations.",
  "permissions": [],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "devtools_page": "devtools.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ]
}
