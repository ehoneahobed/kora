{
  "name": "@korajs/test",
  "version": "0.6.0",
  "description": "Testing harness for Kora.js — create virtual device networks and assert convergence",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@korajs/core": "workspace:*",
    "@korajs/merge": "workspace:*",
    "@korajs/store": "workspace:*",
    "@korajs/sync": "workspace:*",
    "@korajs/server": "workspace:*",
    "better-sqlite3": "^12.8.0"
  },
  "peerDependencies": {
    "korajs": "workspace:*"
  },
  "peerDependenciesMeta": {
    "korajs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4",
    "yjs": "^13.6.30"
  },
  "license": "MIT"
}
