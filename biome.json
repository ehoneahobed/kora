{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "error"
			},
			"style": {
				"noNonNullAssertion": "error"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "all",
			"semicolons": "asNeeded"
		}
	},
	"files": {
		"ignore": ["node_modules", "dist", ".turbo", "coverage", "*.json"]
	},
	"overrides": [
		{
			"include": ["packages/core/src/schema/infer.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		},
		{
			"include": [
				"**/*.test.ts",
				"**/*.test.tsx",
				"**/tests/**",
				"e2e/**",
				"packages/cli/templates/**"
			],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off"
					},
					"a11y": {
						"useButtonType": "off"
					}
				}
			}
		}
	]
}
